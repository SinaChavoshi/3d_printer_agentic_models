# =====================================================================
# 3D Printer Agentic Studio - Environment Configuration
# =====================================================================

# Option A: Google Gemini (Vertex AI ADC or API Key)
# GEMINI_API_KEY=your_gemini_api_key_here
# GOOGLE_CLOUD_PROJECT=your_gcp_project_id
# GOOGLE_CLOUD_LOCATION=us-central1

# Option B: OpenAI (or OpenAI-compatible services)
# OPENAI_API_KEY=your_openai_api_key_here

# Option C: Self-Hosted / Local LLM (Ollama, vLLM, LM Studio, LocalAI)
# LLM_PROVIDER=self-hosted
# LLM_BASE_URL=http://localhost:11434/v1
# LLM_MODEL=qwen2.5-coder
